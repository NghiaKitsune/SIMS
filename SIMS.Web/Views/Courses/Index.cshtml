@model IReadOnlyList<SIMS.Domain.Course>
@{
    ViewData["Title"] = "Courses";
    var isAdmin = User.IsInRole("Administrator");
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Courses</h2>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">New course</a>
    }
</div>

<table class="table table-striped">
    <thead>
        <tr><th>Code</th><th>Title</th><th>Credits</th><th>Capacity</th>@if (isAdmin){<th></th>}</tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Code</td>
                <td>@course.Title</td>
                <td>@course.Credits</td>
                <td>@course.Capacity</td>
                @if (isAdmin)
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@course.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Delete @course.Code?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
