@model SIMS.Web.Models.FacultyCourseViewModel
@{
    ViewData["Title"] = "Student Results";
}

<h2>Student Results</h2>
<p>Select a course to view enrolled students and submit grades.</p>

<div class="list-group col-md-6">
    @foreach (var course in Model.Courses)
    {
        <a class="list-group-item list-group-item-action" asp-action="Course" asp-route-id="@course.Id">
            <strong>@course.Code</strong> — @course.Title
        </a>
    }
</div>
