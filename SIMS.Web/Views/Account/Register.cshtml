@model SIMS.Web.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<h2>Student Registration</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="StudentId" class="form-label"></label>
                <input asp-for="StudentId" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="AcademicYear" class="form-label"></label>
                <input asp-for="AcademicYear" class="form-control" placeholder="2025-2026" />
            </div>
            <button type="submit" class="btn btn-primary">Register</button>
            <a asp-action="Login" class="btn btn-link">Back to login</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
